PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/noas?sslmode=disable
DOMAIN=localhost:3000
EMAIL_VERIFICATION_MODE=required_nip05_domains
# Modes: off | required | required_nip05_domains
VERIFICATION_EXPIRY_MINUTES=15
RESEND_COOLDOWN_MINUTES=1
# Optional. Single domain (`example.com`) or comma-separated (`noas.progyssey.org,noas.polygon.gmbh`).
# Leave empty to default to the request host per tenant.
NIP05_DOMAIN=localhost
NOAS_PUBLIC_URL=http://localhost:3000
NOAS_BASE_PATH=
ALLOWED_ORIGINS=
# Relay URLs to return for new users (relay can enforce publish auth by NIP-05 domain whitelist)
TENANT_DEFAULT_RELAYS=
# Domain-specific relay mapping in form:
# DOMAIN_RELAY_MAP=polygon.gmbh=wss://tasks.polygon.gmbh;acme.com=wss://tasks.acme.com
DOMAIN_RELAY_MAP=
# Comma-separated HTTP(S) relay admin endpoints that receive JSON-RPC allowpubkey requests after verification.
NIP86_RELAY_URLS=
# JSON-RPC method name used for relay allow requests.
NIP86_METHOD=allowpubkey
# Timeout (milliseconds) for each relay request.
NIP86_TIMEOUT_MS=5000
NOAS_API_VERSION=
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=30
EXPOSE_VERIFICATION_TOKEN_IN_RESPONSE=false
REQUIRE_EMAIL_DELIVERY=false

# SMTP options (set either SMTP_URL or SMTP_HOST/SMTP_PORT + auth)
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=
SMTP_REJECT_UNAUTHORIZED=true

# Optional stable signer identity for NIP-46 (`nsec` or 64-char hex)
NIP46_SIGNER_PRIVATE_KEY=
# Comma-separated relay URLs to advertise in `bunker://` tokens
NIP46_RELAYS=
