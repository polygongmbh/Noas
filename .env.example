# --- Core Server ---
PORT=3000
DOMAIN=localhost:3000
DATABASE_URL=postgresql://user:password@localhost:5432/noas?sslmode=disable
# Optional base path if Noas is served under a sub-path (e.g. /noas).
NOAS_BASE_PATH=
# Optional CORS allowlist for browser clients (comma-separated origins).
ALLOWED_ORIGINS=

# Comma-separated initial admin identifiers at registration time (username and/or 64-char hex pubkey).
NOAS_ADMIN_USERS=
# Comma-separated usernames that cannot be registered.
DISALLOWED_USERNAMES=feed,nostr,rnostr,base,tasks,relay,noas,go,nodex,caldav,calendar,dav,nocal

# --- Account Verification ---
# Modes: off | required | required_nip05_domains
# off: no email verification required
# required: email must be verified, any address allowed
# required_nip05_domains: email must be username@NIP05_DOMAIN and verified
EMAIL_VERIFICATION_MODE=required_nip05_domains
VERIFICATION_EXPIRY_MINUTES=15
# Minutes before a verification link expires for activation/resend.
RESEND_COOLDOWN_MINUTES=1

# --- Multi-Tenant Domain Routing ---
# Optional, comma-separated (`progyssey.org,example.com`).
# If set, Noas selects the matching domain based on the request host (subdomains like `noas.example.com` map to `example.com`).
# Leave empty to default to the request host.
# NIP05_DOMAIN=localhost
# Public URL used in verification links and client discovery.
# Leave empty to derive from the request host (recommended for multi-tenancy).
# NOAS_PUBLIC_URL=http://localhost:3000

# --- Relay Discovery For Clients ---
# Relay URLs to return for new users (relay can enforce publish auth by NIP-05 domain whitelist).
# Also published as `noas.relays` in GET /.well-known/nostr.json so clients can
# adopt a default space without any per-account configuration.
TENANT_DEFAULT_RELAYS=
# Domain-specific relay mapping (wins over TENANT_DEFAULT_RELAYS for the matching
# root domain, both at sign-in and in the discovery `noas.relays` array):
# DOMAIN_RELAY_MAP=example.com=wss://tasks.example.com;acme.com=wss://feed.acme.com

# --- Relay Access Provisioning ---
# Comma-separated HTTP(S) relay admin endpoints that receive JSON-RPC allowpubkey requests after verification.
NIP86_RELAY_URLS=
# Optional per-domain relay admin endpoint mapping:
# DOMAIN_NIP86_RELAY_MAP=example.com=https://tasks.example.com

# Optional override for the reported API version (defaults to package.json version).
NOAS_API_VERSION=

# --- SMTP ---
# SMTP options (set either SMTP_URL or SMTP_HOST/SMTP_PORT + auth)
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=
SMTP_REJECT_UNAUTHORIZED=true

# --- NIP-46 Signer Identity ---
# Optional stable signer identity for NIP-46 (`nsec` or 64-char hex)
NIP46_SIGNER_PRIVATE_KEY=

# --- Master-Key Custody ---
# NIP-49 password used to encrypt keys of service-provisioned accounts
# (custody = master_key). Generate a strong random secret, e.g.
# `openssl rand -hex 32`. Required for POST /api/v1/service/accounts and
# for signing with custodial accounts.
CUSTODY_MASTER_KEY=
